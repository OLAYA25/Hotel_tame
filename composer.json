{
    "name": "hoteltame/pms-backend",
    "description": "Hotel Tame PMS - Property Management System Backend",
    "type": "project",
    "version": "2.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Hotel Tame Team",
            "email": "info@hoteltame.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "vlucas/phpdotenv": "^5.4",
        "monolog/monolog": "^3.2",
        "firebase/php-jwt": "^6.6",
        "phpmailer/phpmailer": "^6.8",
        "ramsey/uuid": "^4.7",
        "symfony/console": "^6.3",
        "doctrine/orm": "^2.15"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.3",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.35",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "backend/src/",
            "Config\\": "config/",
            "Database\\": "database/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "analyze": "phpstan analyse",
        "fix": "php-cs-fixer fix",
        "check": [
            "@analyze",
            "@test"
        ],
        "migrate": "php bin/console migrate",
        "serve": "php -S localhost:8000 -t public"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
