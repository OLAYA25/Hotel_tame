# -----------------------------------------------------------------------------
# Hotel Tame — copia este archivo a ".env" y ajusta valores (local vs hosting).
# composer install crea .env desde aquí si no existe.
# -----------------------------------------------------------------------------

# Entorno: development (local) | production (hosting)
APP_ENV=development
APP_DEBUG=true
APP_KEY=base64:YourSecretKeyHere

# URL pública del proyecto (sin barra final)
APP_URL=http://localhost/Hotel_tame

# Prefijo de ruta bajo el dominio (debe coincidir con RewriteBase en .htaccess)
# Ej. carpeta public_html/Hotel_tame → /Hotel_tame
# Si el sitio está en la raíz del dominio, deja vacío: APP_BASE_PATH=
APP_BASE_PATH=/Hotel_tame

# Base de datos — local típico (XAMPP)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=hotel_management_system
DB_USERNAME=root
DB_PASSWORD=""
DB_CHARSET=utf8mb4
DB_COLLATION="utf8mb4_unicode_ci"

# --- Ejemplo hosting (cPanel): descomenta y rellena en tu .env real ---
 #APP_ENV=production
# Base de datos — local típico (XAMPP)
#DB_HOST=localhost
#DB_PORT=3306
#DB_DATABASE=cymconst_hotel_management_system
#DB_USERNAME=cymconst_hotel
#DB_PASSWORD=UDX?bV?{uPPs}[)q
#DB_CHARSET=utf8mb4
#DB_COLLATION="utf8mb4_unicode_ci"
#APP_DEBUG=true
#APP_URL=https://hotel-tame.com.cymconstructorasas.com/Hotel_tame
#APP_BASE_PATH=/Hotel_tame


CACHE_DRIVER=file
CACHE_PREFIX=hoteltame_

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=info@hoteltame.com
MAIL_FROM_NAME="Hotel Tame"

JWT_SECRET=your-jwt-secret-key-here
JWT_TTL=3600
JWT_REFRESH_TTL=604800

LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_PATH=logs

BCRYPT_ROUNDS=12
HASH_DRIVER=bcrypt
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

HOTEL_NAME="Hotel Tame"
HOTEL_TIMEZONE=America/Bogota
HOTEL_CURRENCY=COP
HOTEL_CHECKIN_TIME=15:00
HOTEL_CHECKOUT_TIME=12:00

API_RATE_LIMIT=1000
API_RATE_LIMIT_WINDOW=3600
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,doc,docx
