# Environment Configuration
APP_ENV=development
APP_DEBUG=true
APP_KEY=base64:YourSecretKeyHere
APP_URL=http://localhost:8000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=hotel_management_system
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Cache Configuration
CACHE_DRIVER=file
CACHE_PREFIX=hoteltame_

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=info@hoteltame.com
MAIL_FROM_NAME="Hotel Tame"

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here
JWT_TTL=3600
JWT_REFRESH_TTL=604800

# Logging Configuration
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_PATH=logs

# Security Configuration
BCRYPT_ROUNDS=12
HASH_DRIVER=bcrypt
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# Hotel Configuration
HOTEL_NAME="Hotel Tame"
HOTEL_TIMEZONE=America/Bogota
HOTEL_CURRENCY=COP
HOTEL_CHECKIN_TIME=15:00
HOTEL_CHECKOUT_TIME=12:00

# API Configuration
API_RATE_LIMIT=1000
API_RATE_LIMIT_WINDOW=3600
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# File Upload Configuration
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,doc,docx
